include "conexao.php";

if (isset($_POST['cadastrar'])):

    $em = trim($_POST['emailnumero']);  
    $senha = trim($_POST['senha']);
    
    if (!preg_match('/^(?=.*[a-z])(?=.*[A-Z])(?=.*[\W_]).{8,}$/', $senha)) {
        echo "A senha deve ter no mínimo 8 caracteres, conter uma letra maiúscula, uma minúscula e um símbolo.";
        exit;
    }


    function validaCPF($cpf) {
        $cpf = preg_replace('/[^0-9]/', '', $cpf); 
        if (strlen($cpf) != 11) return false;
        if (preg_match('/(\d)\1{10}/', $cpf)) return false;
        for ($t = 9; $t < 11; $t++) {
            for ($d = 0, $c = 0; $c < $t; $c++) $d += $cpf[$c] * (($t + 1) - $c);
            $d = ((10 * $d) % 11) % 10;
            if ($cpf[$c] != $d) return false;
        }
        return true;
    }


    $vcpf = validaCPF($em);
    $vemail = filter_var($em, FILTER_VALIDATE_EMAIL);
    $is_telefone = preg_match('/^[0-9]{10,11}$/', $em);

    if (!$vemail && !$is_telefone && !$vcpf) {
        echo 'Digite um email, telefone ou CPF válido! ';
        exit;
    }
    if ($vcpf) {
        $entrada_final = password_hash($em, PASSWORD_DEFAULT);
    } else {
        $entrada_final = $em;
    }

    $senha_final = password_hash($senha, PASSWORD_DEFAULT);


    $sql = mysqli_query($conexao, 
        "INSERT INTO `cadastro`(`emailnumero`, `senha`) 
        VALUES ('$entrada_final','$senha_final')"
    );

    if ($sql) {
        echo 'Cadastrado com sucesso! <br>';
    } else {
        echo 'Erro ao cadastrar:   ' . mysqli_error($conexao);
    }

endif;
